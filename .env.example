# ─── Required (production + local) ───

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Application
NEXT_PUBLIC_APP_URL=

# ─── Required for production only ───

# Sentry (if enabled)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Vercel KV (for rate limiting + caching)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Admin access
ADMIN_EMAILS=

# ─── Optional ───

# Database (Drizzle will use DATABASE_URL if set, otherwise Supabase env)
DATABASE_URL=

# Node environment
NODE_ENV=development